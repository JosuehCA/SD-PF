# Django settings
DJANGO_SECRET_KEY=your-production-secret-key-here
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# AES-256 encryption key for clinical data (base64-encoded 32 bytes)
# Generate with: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
CLINICAL_DATA_KEY=your-base64-encoded-32-byte-key-here

# Shared secret for token server authentication
TOKEN_SERVER_SECRET=your-strong-shared-secret-here

# Token server URL
TOKEN_SERVER_URL=http://127.0.0.1:5001
